{
  "name": "@halo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "db:generate": "node -r ./drizzle-kit-esm-fix.cjs node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "node -r ./drizzle-kit-esm-fix.cjs node_modules/drizzle-kit/bin.cjs studio",
    "db:seed:content": "tsx src/jobs/seed-content-runner.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@google-cloud/kms": "^5.4.0",
    "@google-cloud/pino-logging-gcp-config": "^1.3.1",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@halo/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@sentry/node": "^10.39.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "firebase-admin": "^13.6.1",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "resend": "^6.9.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
