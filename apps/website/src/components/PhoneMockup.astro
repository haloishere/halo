---
interface Props {
  src: string
  alt: string
  class?: string
  loading?: 'eager' | 'lazy'
}

const { src, alt, class: className, loading = 'lazy' } = Astro.props
---

<div class:list={['relative inline-block', className]}>
  <!-- Phone frame -->
  <div class="relative bg-halo-dark rounded-[2.5rem] pt-6 pb-6 px-3 shadow-2xl">
    <!-- Screen -->
    <div class="relative rounded-[1.5rem] overflow-hidden bg-white">
      <img
        src={src}
        alt={alt}
        width="622"
        height="1280"
        class="w-full h-auto block"
        loading={loading}
      />
    </div>
  </div>
</div>
