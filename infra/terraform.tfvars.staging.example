# Copy to terraform.tfvars.staging (gitignored) or set as TFC workspace variables.
# DO NOT commit actual values — this file is a template only.

project_id         = "YOUR_GCP_PROJECT_ID"
environment        = "staging"
region             = "us-central1"
github_org         = "YOUR_GITHUB_ORG"
github_repo        = "halo-v1"
db_instance_tier   = "db-f1-micro"
min_instance_count = 0 # set to 1 for production (avoids cold start)

